    <script>
        // --- Data Store (Simulated) ---
        let depositsData = [];
        let currentDepositIdForAction = null;

        // --- Formatting Helper Functions ---
        function formatAmount(amount) {
            if (typeof amount !== 'string') {
                amount = String(amount);
            }
            return amount.replace(/[\s,]/g, '').replace(/\B(?=(\d{3})+(?!\d))/g, ",");
        }

        function formatAmountInput(inputElement) {
            let value = inputElement.value.replace(/[\s,]/g, '');
            inputElement.value = formatAmount(value);
        }

        function formatCardNumber(cardNumber) {
            if (typeof cardNumber !== 'string') {
                cardNumber = String(cardNumber);
            }
            const digitsOnly = cardNumber.replace(/\D/g, '');
            return digitsOnly.replace(/(.{4})/g, '$1-').replace(/-$/, '');
        }

        function formatCardNumberInput(inputElement) {
            inputElement.value = formatCardNumber(inputElement.value);
        }

        // --- DOM Elements ---
        const sidebar = document.getElementById('sidebar');
        const hamburger = document.getElementById('hamburger');
        const overlay = document.getElementById('overlay');
        const loginModal = document.getElementById('login-modal');
        const mainPageSection = document.getElementById('main-page');
        const newDepositSection = document.getElementById('new-deposit-section');
        const depositListSection = document.getElementById('deposit-list-section');
        const depositDetailSection = document.getElementById('deposit-detail-section');
        const editDepositSection = document.getElementById('edit-deposit-section');
        const mediaSection = document.getElementById('media-section');
        const supportSection = document.getElementById('support-section');
        const guideSection = document.getElementById('guide-section');
        const logoutModal = document.getElementById('logout-modal');
        const deleteModal = document.getElementById('delete-modal');
        const depositFormContainer = document.getElementById('deposit-form-container');
        const guideLogoutButton = document.getElementById('guide-logout-button');
        const depositAmountInput = document.getElementById('deposit-amount');
        const depositCardNumberInput = document.getElementById('deposit-card-number');
        const editDepositAmountInput = document.getElementById('edit-deposit-amount');
        const editDepositCardNumberInput = document.getElementById('edit-deposit-card-number');

        let isLoggedIn = false;
        let activeSectionId = 'login-modal';

        // --- Initialization ---
        window.onload = () => {
            const storedDeposits = localStorage.getItem('depositsData');
            if (storedDeposits) {
                depositsData = JSON.parse(storedDeposits);
            }

            if (localStorage.getItem('hasLoggedInBefore')) {
                isLoggedIn = true;
                loginModal.classList.remove('open');
                document.body.style.overflow = 'auto';
                showSection('main-page');
                updateActiveNavLink('nav-home');
                displayDepositList();
            } else {
                isLoggedIn = false;
                loginModal.classList.add('open');
                document.body.style.overflow = 'hidden';
                document.querySelector('.container').style.display = 'none';
            }
            updateVisibilityBasedOnLogin();
        };

        // --- Visibility and Navigation ---
        function updateVisibilityBasedOnLogin() {
            if (isLoggedIn) {
                guideLogoutButton.style.display = 'block';
                document.querySelector('.container').style.display = 'block';
            } else {
                guideLogoutButton.style.display = 'none';
                document.querySelector('.container').style.display = 'none';
            }
        }

        function showSection(sectionId) {
            document.querySelectorAll('.container > section').forEach(section => {
                section.style.display = 'none';
            });

            const sectionToShow = document.getElementById(sectionId);
            if (sectionToShow) {
                sectionToShow.style.display = 'block';
                activeSectionId = sectionId;

                let navId = 'nav-home';
                if (sectionId === 'main-page') navId = 'nav-home';
                else if (sectionId === 'new-deposit-section') navId = 'nav-new-deposit';
                else if (sectionId === 'deposit-list-section') navId = 'nav-list';
                else if (sectionId === 'media-section') navId = 'nav-media';
                else if (sectionId === 'support-section') navId = 'nav-support';
                else if (sectionId === 'guide-section') navId = 'nav-guide';
                updateActiveNavLink(navId);

                updateVisibilityBasedOnLogin();
            }
        }

        function hideSection(sectionId) {
             const sectionToHide = document.getElementById(sectionId);
             if(sectionToHide) {
                 sectionToHide.style.display = 'none';
             }
        }

        function updateActiveNavLink(clickedNavId) {
            document.querySelectorAll('.sidebar li').forEach(item => {
                item.classList.remove('active');
            });
            const activeNav = document.getElementById(clickedNavId);
            if (activeNav) {
                activeNav.classList.add('active');
            }
        }

        // Sidebar toggle
        hamburger.addEventListener('click', () => {
            sidebar.classList.toggle('open');
            overlay.classList.toggle('open');
        });
        overlay.addEventListener('click', () => {
            sidebar.classList.remove('open');
            overlay.classList.remove('open');
        });

        // Sidebar navigation clicks
        document.querySelectorAll('.sidebar li').forEach(item => {
            item.addEventListener('click', () => {
                sidebar.classList.remove('open');
                overlay.classList.remove('open');

                let targetSection = '';
                if (item.id === 'nav-home') targetSection = 'main-page';
                else if (item.id === 'nav-new-deposit') targetSection = 'new-deposit-section';
                else if (item.id === 'nav-list') targetSection = 'deposit-list-section';
                else if (item.id === 'nav-media') targetSection = 'media-section';
                else if (item.id === 'nav-support') targetSection = 'support-section';
                else if (item.id === 'nav-guide') targetSection = 'guide-section';

                if (targetSection) {
                    showSection(targetSection);
                }
                updateActiveNavLink(item.id);
            });
        });

        // --- Login Modal and User Management ---
        function loginUser() {
            const phoneNumber = document.getElementById('phone-number').value;
            if (phoneNumber) {
                isLoggedIn = true;
                localStorage.setItem('hasLoggedInBefore', 'true');

                loginModal.classList.remove('open');
                document.body.style.overflow = 'auto';
                overlay.classList.remove('open');
                showSection('main-page');
                updateActiveNavLink('nav-home');
                updateVisibilityBasedOnLogin();
                displayDepositList();

                if (!localStorage.getItem('welcomeMessageShown')) {
                     alert("ثبت نام شما با موفقیت انجام شد!");
                     localStorage.setItem('welcomeMessageShown', 'true');
                 }
            } else {
                alert("لطفاً شماره تلفن خود را وارد کنید.");
            }
        }

        function logoutUser() {
            isLoggedIn = false;
            localStorage.removeItem('hasLoggedInBefore');
            localStorage.removeItem('welcomeMessageShown');
            localStorage.removeItem('depositsData');
            depositsData = [];

            document.body.style.overflow = 'hidden';
            closeLogoutModal();

            loginModal.classList.add('open');
            showSection('main-page');
            document.querySelector('.container').style.display = 'none';
            updateVisibilityBasedOnLogin();
        }

        function confirmLogout() {
             logoutUser();
        }

        function openLogoutModal() {
            logoutModal.classList.add('open');
            overlay.classList.add('open');
            document.body.style.overflow = 'hidden';
        }

        function closeLogoutModal() {
            logoutModal.classList.remove('open');
            overlay.classList.remove('open');
            document.body.style.overflow = 'auto';
        }

        // --- Deposit Management ---
        function toggleDepositForm() {
            const formContainer = document.getElementById('deposit-form-container');
            if (formContainer.style.display === 'none' || formContainer.style.display === '') {
                formContainer.style.display = 'block';
            } else {
                formContainer.style.display = 'none';
            }
        }

        function getCurrentPersianYear() {
            const today = new Date();
            const persian_year = today.toLocaleDateString('fa-IR').split('/')[0];
            return parseInt(persian_year, 10);
        }

        function saveDepositInfo() {
            const depositorName = document.getElementById('depositor-name').value;
            const depositYear = parseInt(document.getElementById('deposit-year').value, 10);
            const depositMonth = parseInt(document.getElementById('deposit-month').value, 10);
            const depositDay = parseInt(document.getElementById('deposit-day').value, 10);
            const depositHour = parseInt(document.getElementById('deposit-hour').value, 10);
            const depositMinute = parseInt(document.getElementById('deposit-minute').value, 10);
            const depositAmount = document.getElementById('deposit-amount').value.replace(/[\s,]/g, '');
            const depositCardNumber = document.getElementById('deposit-card-number').value.replace(/\D/g, '');
            const depositDescription = document.getElementById('deposit-description').value;
            const noDescriptionCheckbox = document.getElementById('no-description-checkbox').checked;

            if (!depositorName || isNaN(depositYear) || isNaN(depositMonth) || isNaN(depositDay) || 
                isNaN(depositHour) || isNaN(depositMinute) || !depositAmount) {
                alert("لطفاً تمامی کادرهای الزامی (نام، تاریخ، زمان، مبلغ) را پر کنید.");
                return;
            }
            if (depositYear < 1300 || depositYear > getCurrentPersianYear() + 5) {
                alert("سال وارد شده معتبر نیست.");
                return;
            }
            if (depositMonth < 1 || depositMonth > 12) {
                alert("ماه وارد شده باید بین ۱ تا ۱۲ باشد.");
                return;
            }
            if (depositDay < 1 || depositDay > 31) {
                alert("روز وارد شده باید بین ۱ تا ۳۱ باشد.");
                return;
            }
            if (depositHour < 0 || depositHour > 23) {
                alert("ساعت وارد شده باید بین ۰۰ تا ۲۳ باشد.");
                return;
            }
            if (depositMinute < 0 || depositMinute > 59) {
                alert("دقیقه وارد شده باید بین ۰۰ تا ۵۹ باشد.");
                return;
            }
            if (depositCardNumber.length > 0 && depositCardNumber.length !== 16) {
                alert("شماره کارت باید ۱۶ رقمی باشد.");
                return;
            }

            const formattedDate = `${depositYear}/${String(depositMonth).padStart(2, '0')}/${String(depositDay).padStart(2, '0')}`;
            const formattedTime = `${String(depositHour).padStart(2, '0')}:${String(depositMinute).padStart(2, '0')}`;

            let finalDescription = depositDescription;
            if (noDescriptionCheckbox) {
                finalDescription = "";
                document.getElementById('no-description-checkbox').checked = false;
            }

            const newDeposit = {
                id: Date.now(),
                depositorName: depositorName,
                depositDate: formattedDate,
                depositTime: formattedTime,
                depositAmount: depositAmount,
                depositCardNumber: depositCardNumber,
                depositDescription: finalDescription
            };

            depositsData.push(newDeposit);
            localStorage.setItem('depositsData', JSON.stringify(depositsData));
            alert("اطلاعات واریزی با موفقیت ثبت شد!");

            document.getElementById('depositor-name').value = '';
            document.getElementById('deposit-year').value = '';
            document.getElementById('deposit-month').value = '';
            document.getElementById('deposit-day').value = '';
            document.getElementById('deposit-hour').value = '';
            document.getElementById('deposit-minute').value = '';
            depositAmountInput.value = '';
            depositCardNumberInput.value = '';
            document.getElementById('deposit-description').value = '';
            document.getElementById('no-description-checkbox').checked = false;

            toggleDepositForm();
            showSection('deposit-list-section');
            updateActiveNavLink('nav-list');
            displayDepositList();
        }

        function displayDepositList() {
            const listContainer = document.getElementById('deposit-list-items');
            listContainer.innerHTML = '';

            if (depositsData.length === 0) {
                listContainer.innerHTML = '<p style="text-align: center; color: #777;">هیچ واریزی ثبت نشده است.</p>';
                return;
            }

            depositsData.sort((a, b) => {
                const dateTimeA = new Date(`${a.depositDate.replace(/\//g, '-')}T${a.depositTime}:00`);
                const dateTimeB = new Date(`${b.depositDate.replace(/\//g, '-')}T${b.depositTime}:00`);
                return dateTimeB - dateTimeA;
            });

            depositsData.forEach(deposit => {
                const itemDiv = document.createElement('div');
                itemDiv.className = 'deposit-item';
                itemDiv.dataset.id = deposit.id;
                const formattedDisplayAmount = formatAmount(deposit.depositAmount);
                itemDiv.innerHTML = `
                    <div class="info">
                        <span>تاریخ: ${deposit.depositDate}</span>
                        <span>مبلغ: ${formattedDisplayAmount} تومان</span>
                        <span>زمان: ${deposit.depositTime}</span>
                    </div>
                    <button class="btn btn-primary details-link" onclick="showDepositDetails(${deposit.id})">مشاهده کامل اطلاعات</button>
                `;
                listContainer.appendChild(itemDiv);
            });
        }

        function showDepositDetails(depositId) {
            currentDepositIdForAction = depositId;
            const deposit = depositsData.find(d => d.id === depositId);

            if (deposit) {
                document.getElementById('detail-depositor-name').textContent = deposit.depositorName;
                document.getElementById('detail-deposit-date').textContent = deposit.depositDate;
                document.getElementById('detail-deposit-time').textContent = deposit.depositTime;
                document.getElementById('detail-deposit-amount').textContent = formatAmount(deposit.depositAmount) + ' تومان';

                let formattedCardNumber = deposit.depositCardNumber || 'ثبت نشده';
                if (formattedCardNumber.length === 16) {
                    formattedCardNumber = `${formattedCardNumber.substring(0, 4)}-${formattedCardNumber.substring(4, 8)}-${formattedCardNumber.substring(8, 12)}-${formattedCardNumber.substring(12, 16)}`;
                } else if (formattedCardNumber.length > 0) {
                     formattedCardNumber = formatCardNumber(formattedCardNumber);
                }
                document.getElementById('detail-deposit-card-number').textContent = formattedCardNumber;
                document.getElementById('detail-deposit-description').textContent = deposit.depositDescription || 'توضیحات وارد نشده است.';

                showSection('deposit-detail-section');
                updateActiveNavLink('nav-list');
            } else {
                alert("اطلاعات واریزی یافت نشد.");
            }
        }

        function editDepositInfo(depositId) {
             const deposit = depositsData.find(d => d.id === depositId);
             if (deposit) {
                 document.getElementById('edit-depositor-name').value = deposit.depositorName;

                 const dateParts = deposit.depositDate.split('/');
                 if (dateParts.length === 3) {
                     document.getElementById('edit-deposit-year').value = dateParts[0];
                     document.getElementById('edit-deposit-month').value = parseInt(dateParts[1], 10);
                     document.getElementById('edit-deposit-day').value = parseInt(dateParts[2], 10);
                 }

                 const timeParts = deposit.depositTime.split(':');
                 if (timeParts.length === 2) {
                     document.getElementById('edit-deposit-hour').value = parseInt(timeParts[0], 10);
                     document.getElementById('edit-deposit-minute').value = parseInt(timeParts[1], 10);
                 }

                 editDepositAmountInput.value = formatAmount(deposit.depositAmount);
                 editDepositCardNumberInput.value = formatCardNumber(deposit.depositCardNumber);
                 document.getElementById('edit-deposit-description').value = deposit.depositDescription;
                 document.getElementById('edit-no-description-checkbox').checked = (deposit.depositDescription === "");

                 editDepositSection.dataset.currentDepositId = depositId;
                 currentDepositIdForAction = depositId;

                 showSection('edit-deposit-section');
                 updateActiveNavLink('nav-list');
             } else {
                 alert("اطلاعات واریزی یافت نشد.");
             }
        }

        function updateDepositInfo(depositId) {
             const depositorName = document.getElementById('edit-depositor-name').value;
             const depositYear = parseInt(document.getElementById('edit-deposit-year').value, 10);
             const depositMonth = parseInt(document.getElementById('edit-deposit-month').value, 10);
             const depositDay = parseInt(document.getElementById('edit-deposit-day').value, 10);
             const depositHour = parseInt(document.getElementById('edit-deposit-hour').value, 10);
             const depositMinute = parseInt(document.getElementById('edit-deposit-minute').value, 10);
             const depositAmount = document.getElementById('edit-deposit-amount').value.replace(/[\s,]/g, '');
             const depositCardNumber = document.getElementById('edit-deposit-card-number').value.replace(/\D/g, '');
             const depositDescription = document.getElementById('edit-deposit-description').value;
             const noDescriptionCheckbox = document.getElementById('edit-no-description-checkbox').checked;

             if (!depositorName || isNaN(depositYear) || isNaN(depositMonth) || isNaN(depositDay) || 
                 isNaN(depositHour) || isNaN(depositMinute) || !depositAmount) {
                 alert("لطفاً تمامی کادرهای الزامی (نام، تاریخ، زمان، مبلغ) را پر کنید.");
                 return;
             }
             if (depositYear < 1300 || depositYear > getCurrentPersianYear() + 5) {
                 alert("سال وارد شده معتبر نیست.");
                 return;
             }
             if (depositMonth < 1 || depositMonth > 12) {
                 alert("ماه وارد شده باید بین ۱ تا ۱۲ باشد.");
                 return;
             }
             if (depositDay < 1 || depositDay > 31) {
                 alert("روز وارد شده باید بین ۱ تا ۳۱ باشد.");
                 return;
             }
             if (depositHour < 0 || depositHour > 23) {
                 alert("ساعت وارد شده باید بین ۰۰ تا ۲۳ باشد.");
                 return;
             }
             if (depositMinute < 0 || depositMinute > 59) {
                 alert("دقیقه وارد شده باید بین ۰۰ تا ۵۹ باشد.");
                 return;
             }
             if (depositCardNumber.length > 0 && depositCardNumber.length !== 16) {
                 alert("شماره کارت باید ۱۶ رقمی باشد.");
                 return;
             }

            const formattedDate = `${depositYear}/${String(depositMonth).padStart(2, '0')}/${String(depositDay).padStart(2, '0')}`;
            const formattedTime = `${String(depositHour).padStart(2, '0')}:${String(depositMinute).padStart(2, '0')}`;

            let finalDescription = depositDescription;
            if (noDescriptionCheckbox) {
                finalDescription = "";
                document.getElementById('edit-no-description-checkbox').checked = false;
            }

            const depositIndex = depositsData.findIndex(d => d.id === depositId);
            if (depositIndex !== -1) {
                depositsData[depositIndex] = {
                    ...depositsData[depositIndex],
                    depositorName,
                    depositDate: formattedDate,
                    depositTime: formattedTime,
                    depositAmount: depositAmount,
                    depositCardNumber: depositCardNumber,
                    depositDescription: finalDescription
                };
                localStorage.setItem('depositsData', JSON.stringify(depositsData));
                alert("اطلاعات واریزی با موفقیت به‌روزرسانی شد!");

                // به‌روزرسانی لیست واریزی‌ها
                displayDepositList();
                
                hideSection('edit-deposit-section');
                // نمایش جزئیات به‌روز شده
                showDepositDetails(depositId);
            } else {
                alert("خطا در به‌روزرسانی: واریزی یافت نشد.");
            }
        }

        // --- Delete Functionality ---
        function openDeleteModal(depositId) {
            currentDepositIdForAction = depositId;
            deleteModal.classList.add('open');
            overlay.classList.add('open');
            document.body.style.overflow = 'hidden';
        }

        function closeDeleteModal() {
            deleteModal.classList.remove('open');
            overlay.classList.remove('open');
            document.body.style.overflow = 'auto';
            currentDepositIdForAction = null;
        }

        function confirmDelete() {
            if (currentDepositIdForAction === null) {
                alert("خطا: شناسه واریزی برای حذف مشخص نشده است.");
                closeDeleteModal();
                return;
            }

            const initialLength = depositsData.length;
            depositsData = depositsData.filter(deposit => deposit.id !== currentDepositIdForAction);

            if (depositsData.length < initialLength) {
                localStorage.setItem('depositsData', JSON.stringify(depositsData));
                alert("واریزی با موفقیت حذف شد.");
                displayDepositList();
                hideSection('deposit-detail-section');
                showSection('deposit-list-section');
                updateActiveNavLink('nav-list');
            } else {
                alert("خطا در حذف: واریزی یافت نشد.");
            }

            closeDeleteModal();
        }
    </script>
</body>
</html>
